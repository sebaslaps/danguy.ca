---
import BaseLayout from '../layouts/BaseLayout.astro';

const panels = [
  ['Excavation et terrassement', 'Travaux résidentiels et commerciaux de petite envergure, préparation de terrain, nivellement et finition.'],
  ['Centre de vrac', 'Pierre, sable, paillis, terre, compost, gravier, concassé et autres matériaux disponibles au public.'],
  ['Drains, ponceaux et tuyaux', 'Tuyaux et accessoires BNQ, SDR et autres, membranes géotextiles, drains et ponceaux.'],
  ['Installations septiques', 'Solutions septiques adaptées aux besoins du projet et aux conditions du terrain.'],
];

const services = [
  'Excavation',
  'Terrassement',
  'Installations septiques',
  'Aménagement de quais en pierre',
  'Démolition',
  'Livraison de matériaux',
  'Déneigement de cours commerciales et industrielles',
  'Matériaux en vrac',
  'Drains et ponceaux',
  'Tuyaux et accessoires BNQ, SDR et autres',
  'Membranes géotextiles',
  'Semence',
  'Cœurs de porte',
  'Location d’espaces extérieurs',
  'Location de terrains',
];

---
<BaseLayout
  title="Installations septiques Sainte-Marie | Services | Excavation Danguy Inc."
  description="Services d’excavation, terrassement, installations septiques, livraison de matériaux, drains, ponceaux et matériaux en vrac à Sainte-Marie."
  active="/services/"
>
  <section class="service-panels-section" aria-label="Aperçu des services">
    <div class="service-panel-grid">
      {panels.map(([title, text]) => (
        <a href="#services" class="service-panel">
          <span class="panel-title">{title}</span>
          <span class="panel-text">{text}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="page-section intro-services">
    <div class="container content-narrow">
      <h1>À Sainte-Marie, vos travaux d’excavation sont entre bonnes mains</h1>
      <p class="lead-strong">Nous sommes l’équipe qu’il vous faut!</p>
      <p>Chez Excavation Danguy Inc., votre satisfaction est notre priorité. C’est pourquoi nous nous engageons à vous offrir des services, des travaux et des conseils de qualité. Les sections ci-dessus remplacent les images non confirmées par des repères textuels clairs. Vous avez des questions? <a href="tel:+14183876746">Appelez-nous dès aujourd’hui.</a></p>
    </div>
  </section>

  <section id="services" class="yellow-band services-list-section">
    <div class="container">
      <h2>Services</h2>
      <ul class="plain-list">
        {services.map((service) => <li>{service}</li>)}
      </ul>
    </div>
  </section>

  <section class="black-cta">
    <div class="container">
      <h2>Installations septiques</h2>
      <p>Contactez-nous pour discuter de votre projet d’installation septique et des options adaptées à votre terrain.</p>
      <a class="button-yellow" href="/contactez-nous/">Venez nous voir</a>
    </div>
  </section>
</BaseLayout>

<style>
  .service-panels-section { padding: 68px 0 48px; background: #fff; }
  .service-panel-grid { width: min(940px, calc(100% - 32px)); margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; align-items: stretch; }
  .service-panel { min-height: 210px; display: flex; flex-direction: column; justify-content: space-between; gap: 18px; padding: 24px 18px; color: #111; text-decoration: none; border: 1px solid #e8e8e8; background: linear-gradient(180deg, #fff 0%, #f7f7f7 100%); box-shadow: 0 1px 0 rgba(0,0,0,.08); }
  .service-panel:nth-child(even) { background: var(--yellow); }
  .panel-title { display: block; font-weight: 900; font-size: 1.08rem; text-transform: uppercase; }
  .panel-text { display: block; color: #555; font-size: .95rem; }
  .service-panel:nth-child(even) .panel-text { color: #222; }
  .intro-services { padding-top: 38px; }
  .services-list-section { padding: 54px 0 60px; }
  @media (max-width: 760px) {
    .service-panel-grid { grid-template-columns: 1fr; }
  }
</style>
