---
import BaseLayout from '../layouts/BaseLayout.astro';

const materials = ['Pierre', 'Paillis', 'Terre', 'Sable', 'Compost', 'Fumier', 'Gravier', 'Concassé', 'Pierre décorative', 'Poussière de pierre'];
const specialties = ['Excavation', 'Terrassement', 'Installations septiques', 'Livraison de matériaux', 'Centre de vrac'];
---
<BaseLayout
  title="Excavation Danguy Inc. | Excavation Sainte-Marie | Accueil"
  description="Excavation Danguy Inc. offre des services d’excavation, terrassement, installations septiques et matériaux en vrac à Sainte-Marie."
  active="/"
>
  <section class="home-hero" aria-labelledby="home-slogan">
    <div class="container">
      <p id="home-slogan" class="hero-title">NOTRE SAVOIR-FAIRE AU SERVICE DE VOS PROJETS D'EXCAVATION</p>
      <div class="hero-link-row">
        <a class="hero-link-card" href="/services/">
          <strong>Excavation et terrassement</strong>
          <span>Voir les services</span>
        </a>
        <a class="hero-link-card" href="/services/">
          <strong>Matériaux en vrac</strong>
          <span>Pierre, sable, paillis et plus</span>
        </a>
        <a class="hero-link-card" href="/contactez-nous/">
          <strong>Soumission</strong>
          <span>Contactez-nous</span>
        </a>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container content-narrow">
      <h1>Excavation Danguy Inc., votre spécialiste en excavation à Sainte-Marie</h1>
      <p class="lead-strong">Excavation, terrassement et bien plus!</p>
      <p>Excavation Danguy Inc. offre une <a href="/services/">vaste gamme de services</a> dans le domaine de l’excavation résidentielle et commerciale, pour des travaux de petite envergure. Que ce soit pour de l’excavation, le terrassement, la démolition ou la livraison de matériaux, nous saurons vous donner un service et des conseils de qualité.</p>

      <p class="lead-strong spaced">Installations septiques éprouvées</p>
      <p>Nous sommes installateurs autorisés des produits Biofiltre Ecoflo de Premier Tech Aqua, du système Enviro Septic de DBO Expert Inc. et des installations septiques Bionest. Que ce soit pour le remplacement d’une installation existante ou pour une nouvelle construction, nous pourrons répondre à vos besoins en matière d’installation septique.</p>

      <p class="lead-strong spaced">Vaste sélection de matériaux en vrac</p>
      <p>Vous trouverez à notre centre de vrac, ouvert au public, plus de 45 choix de produits en vrac, tels que :</p>
      <ul class="material-list">
        {materials.map((material) => <li>{material}</li>)}
      </ul>
      <p>Il suffit de vous y présenter avec votre camionnette, votre remorque (« trailer ») ou vos chaudières. Semence, cœurs de porte et plusieurs choix de membranes géotextiles, vendus au pied ou en rouleau, vous sont également offerts. De plus, vous y trouverez des drains, des ponceaux, des tuyaux en polyéthylène haute densité (PEHD) et des tuyaux de tôle ondulée galvanisée (acier – TTOG). Plusieurs diamètres et longueurs sont disponibles en tout temps, dans le but de toujours mieux vous servir.</p>
    </div>
  </section>

  <section class="yellow-band">
    <div class="container">
      <h2>Spécialités</h2>
      <ul class="plain-list">
        {specialties.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero { padding: 142px 0 138px; background: #fff; }
  .hero-title {
    color: var(--yellow);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2.35rem, 5.9vw, 4.2rem);
    line-height: 1.08;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: .01em;
    text-shadow: 4px 6px 7px rgba(0,0,0,.58);
    max-width: 910px;
    margin: 0 auto 66px;
  }
  .hero-link-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; max-width: 850px; margin: 0 auto; }
  .hero-link-card { display: flex; flex-direction: column; gap: 8px; min-height: 112px; padding: 24px 22px; color: #111; text-decoration: none; background: #fff; border: 3px solid var(--yellow); box-shadow: 0 8px 0 #111; }
  .hero-link-card strong { font-size: 1.12rem; text-transform: uppercase; }
  .hero-link-card span { color: #555; font-weight: 700; }
  .hero-link-card:hover { background: var(--yellow); }
  .spaced { margin-top: 28px; }
  .material-list { columns: 2; max-width: 520px; margin: 0 0 22px 20px; padding: 0; }
  .material-list li { margin: 4px 0; }
  @media (max-width: 760px) {
    .home-hero { padding: 72px 0; }
    .hero-link-row { grid-template-columns: 1fr; }
    .material-list { columns: 1; }
  }
</style>
